generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  // تم حذف سطر url من هنا
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  password  String
  role      String
  createdAt DateTime @default(now())
}
